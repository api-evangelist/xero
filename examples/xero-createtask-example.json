        "taskId": "00000000-0000-0000-0000-000000000000",
        "projectId": "00000000-0000-0000-0000-000000000000",
        "totalMinutes": 300,
        "totalAmount": {
          "currency": "AUD",
          "value": 100
        },
        "minutesToBeInvoiced": 300,
        "minutesInvoiced": 0,
        "nonChargeableMinutes": 0,
        "fixedMinutes": 0,
        "amountToBeInvoiced": {
          "currency": "AUD",
          "value": 100
        },
        "amountInvoiced": {
          "currency": "AUD",
          "value": 0
