          }
        ]
      }
    },
    {
      "status": "400",
      "contentType": "application/problem+json",
      "example": {
        "type": "invalid-request",
        "title": "Invalid Request",
        "status": 400,
        "detail": "For the request field 'StatementLine.ChequeNumber' exceeded the maximum length of 20."
