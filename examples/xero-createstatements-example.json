            ]
          }
        ]
      }
    },
    {
      "status": "413",
      "contentType": "application/problem+json",
      "example": {
        "type": "invalid-request",
        "title": "Request too large",
        "status": 413,
        "detail": "Request size of 3500000 bytes exceeds the limit of 3000000 bytes."
      }
    },
    {
      "status": "422",
      "contentType": "application/problem+json",
      "example": {
        "type": "invalid-end-balance",
