              }
            ]
          }
        ]
      }
    }
  ],
  "responseExamples": [
    {
      "status": "202",
      "contentType": "application/json",
      "example": {
        "items": [
          {
            "id": "d69b02b7-a30c-464a-99cf-ba9770373c61",
