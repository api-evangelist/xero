      "example": {
        "Id": "b1ba6cdb-1637-4209-bb92-bd0c593f3243",
        "Status": "OK",
        "ProviderName": "Provider Name Example",
        "DateTimeUTC": "/Date(1551746288544)/",
        "ContactGroups": [
          {
            "ContactGroupID": "13f47537-7c1d-4e62-966e-617d76558fc5",
            "Name": "Supplier Vendor",
            "Status": "ACTIVE",
            "Contacts": [],
            "HasValidationErrors": false
          }
        ]
      }
    }
  ]
}