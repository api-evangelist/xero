  "path": "/ContactGroups/{ContactGroupID}",
  "summary": "Xero Updates a specific contact group",
  "requestExamples": [
    {
      "contentType": "application/json",
      "example": {
        "ContactGroups": [
          {
            "Name": "Suppliers"
          }
        ]
      }
    }
  ],
