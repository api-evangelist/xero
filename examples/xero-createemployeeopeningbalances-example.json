  "requestExamples": [
    {
      "contentType": "application/json",
      "example": "[{\"periodEndDate\":\"2020-10-01\",\"daysPaid\":3,\"unpaidWeeks\":2,\"grossEarnings\":40.0}]"
    }
  ],
  "responseExamples": [
