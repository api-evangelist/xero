            "status": "PENDING"
          }
        ]
      }
    },
    {
      "status": "400",
      "contentType": "application/json",
      "example": {
        "items": [
          {
            "accountToken": "foobar71760",
            "status": "REJECTED",
            "error": {
              "type": "invalid-request",
              "title": "Invalid Request",
