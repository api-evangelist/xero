{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/Files",
  "title": "Files",
  "type": "object",
  "properties": {
    "TotalCount": {
      "type": "integer",
      "example": 2
    },
    "Page": {
      "type": "integer",
      "example": 1
    },
    "PerPage": {
      "type": "integer",
      "example": 50
    },
    "Items": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/FileObject"
      }
    }
  }
}